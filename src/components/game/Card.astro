---
// Carta visual estándar de Zenythic (reutilizable por todos los juegos de cartas)
import type { Card as CardType } from '../../games/engine/types';
import { cardId, isRedSuit, suitSymbol } from '../../games/engine/types';

export interface Props {
  card?: CardType;
  /** Si la carta está boca abajo (sin revelar). */
  faceDown?: boolean;
  /** Animación de entrada: 'deal' reparte desde arriba, 'flip' voltea. */
  animation?: 'deal' | 'flip' | 'none';
}

const { card, faceDown = false, animation = 'deal' } = Astro.props;
const down = faceDown || !card;
const color = card && isRedSuit(card.suit) ? 'text-red-600' : 'text-ink-900';
---

<div
  class:list={[
    'zy-card group relative w-16 h-24 md:w-20 md:h-28 select-none',
    animation === 'deal' && 'zy-card-deal',
    animation === 'flip' && 'zy-card-flip',
  ]}
  data-card-id={card ? cardId(card) : undefined}
>
  {down ? (
    <!-- Reverso: patrón Zenythic -->
    <div class="absolute inset-0 rounded-md bg-ink-900 border border-gold-500/60 shadow-soft">
      <div class="absolute inset-1 border border-gold-500/30 rounded-sm flex items-center justify-center">
        <svg viewBox="0 0 48 48" width="24" height="24" aria-hidden="true">
          <path d="M10 12 H38 L14 36 H38" fill="none" stroke="#C9A961" stroke-width="3" stroke-linecap="square"/>
        </svg>
      </div>
    </div>
  ) : (
    <!-- Anverso -->
    <div class="absolute inset-0 rounded-md bg-white border border-ink-200 shadow-soft flex flex-col justify-between p-1.5">
      <div class={`text-sm md:text-base font-bold leading-none ${color}`}>
        <div>{card!.rank}</div>
        <div class="text-xs md:text-sm leading-none">{suitSymbol(card!.suit)}</div>
      </div>
      <div class={`self-center text-2xl md:text-3xl ${color}`}>{suitSymbol(card!.suit)}</div>
      <div class={`self-end rotate-180 text-sm md:text-base font-bold leading-none ${color}`}>
        <div>{card!.rank}</div>
        <div class="text-xs md:text-sm leading-none">{suitSymbol(card!.suit)}</div>
      </div>
    </div>
  )}
</div>

<style>
  @keyframes zy-deal {
    0% { transform: translateY(-120%) rotate(-8deg); opacity: 0; }
    100% { transform: translateY(0) rotate(0); opacity: 1; }
  }
  @keyframes zy-flip {
    0% { transform: rotateY(90deg); opacity: 0; }
    100% { transform: rotateY(0); opacity: 1; }
  }
  .zy-card-deal { animation: zy-deal 0.45s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .zy-card-flip { animation: zy-flip 0.4s ease-out both; }
</style>
