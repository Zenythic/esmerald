---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = ['catalog', 'api', 'backoffice', 'analytics'];

const icons: Record<string, string> = {
  catalog: 'M4 4 H10 V10 H4 Z M14 4 H20 V10 H14 Z M4 14 H10 V20 H4 Z M14 14 H20 V20 H14 Z',
  api: 'M8 4 H16 A4 4 0 0 1 20 8 V16 A4 4 0 0 1 16 20 H8 A4 4 0 0 1 4 16 V8 A4 4 0 0 1 8 4 Z M8 12 H16',
  backoffice: 'M3 3 H21 V5 H3 Z M3 10 H21 V12 H3 Z M3 17 H21 V19 H3 Z',
  analytics: 'M3 3 V21 H21 M7 14 L11 10 L14 13 L20 7',
};
---

<section class="py-24 md:py-32 bg-ink-50/40">
  <div class="container-z">
    <div class="reveal max-w-2xl">
      <p class="kicker">{t('solutions.kicker')}</p>
      <h2 class="mt-4 text-3xl md:text-5xl font-extrabold tracking-tight text-ink-900">{t('solutions.title')}</h2>
      <p class="mt-4 text-lg text-ink-500">{t('solutions.subtitle')}</p>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-8">
      {items.map((key, i) => (
        <div class="reveal group relative bg-white border border-ink-100 hover:border-gold-400 p-8 transition-colors">
          <span class="hairline-gold absolute top-0 left-0 opacity-0 group-hover:opacity-100 transition-opacity"></span>
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center bg-ink-50 border border-ink-100 text-gold-600">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[key]} />
              </svg>
            </div>
            <div class="flex-1">
              <span class="text-xs font-semibold text-gold-600 tracking-widest2">0{i + 1}</span>
              <h3 class="mt-1 text-xl font-bold text-ink-900">{t(`solutions.items.${key}.title`)}</h3>
              <p class="mt-2 text-sm text-ink-500 leading-relaxed">{t(`solutions.items.${key}.desc`)}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
