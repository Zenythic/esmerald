---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const points = ['iframe', 'sdk', 'webhook', 'sandbox'];
---

<section id="technology" class="py-24 md:py-32 border-t border-ink-100 bg-white">
  <div class="container-z grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Texto -->
    <div class="reveal">
      <p class="kicker">{t('tech.kicker')}</p>
      <h2 class="mt-4 text-3xl md:text-5xl font-extrabold tracking-tight text-ink-900">{t('tech.title')}</h2>
      <p class="mt-4 text-lg text-ink-500">{t('tech.subtitle')}</p>

      <ul class="mt-10 space-y-5">
        {points.map((p) => (
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 mt-0.5 w-6 h-6 flex items-center justify-center border border-gold-400">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C9A961" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class="text-ink-700 leading-relaxed">{t(`tech.points.${p}`)}</span>
          </li>
        ))}
      </ul>

      <a href="#contact" class="btn-ghost mt-10">{t('tech.cta')}</a>
    </div>

    <!-- Bloque código/visual -->
    <div class="reveal">
      <div class="relative bg-ink-900 p-8 shadow-soft">
        <span class="hairline-gold absolute top-0 left-0"></span>
        <!-- Barra terminal -->
        <div class="flex items-center gap-2 mb-6">
          <span class="w-3 h-3 rounded-full bg-ink-700"></span>
          <span class="w-3 h-3 rounded-full bg-ink-700"></span>
          <span class="w-3 h-3 rounded-full bg-gold-400"></span>
          <span class="ml-3 text-xs text-ink-400 font-mono">integration.ts</span>
        </div>
        <pre class="text-xs md:text-sm font-mono leading-relaxed text-ink-300 overflow-x-auto"><span class="text-gold-400">import</span> {'{'} Zenythic {'}'} <span class="text-gold-400">from</span> <span class="text-ink-200">"@zenythic/sdk"</span>;

<span class="text-gold-400">const</span> client = <span class="text-gold-400">new</span> Zenythic({'{'}
  apiKey: <span class="text-ink-200">process.env.ZEN_API_KEY</span>,
  mode:   <span class="text-ink-200">"sandbox"</span>,
{'}'});

<span class="text-ink-400">// monta el juego en tu plataforma</span>
client.games.mount(<span class="text-ink-200">"apex"</span>, targetEl);</pre>
      </div>
    </div>
  </div>
</section>
