---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <!-- Líneas decorativas doradas -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-gold-400/0 via-gold-400/60 to-gold-400/0"></div>
  </div>

  <div class="container-z text-center max-w-4xl mx-auto">
    <p class="kicker reveal justify-center !justify-center mx-auto"> {t('hero.kicker')}</p>

    <h1 class="reveal mt-6 text-4xl md:text-6xl font-extrabold tracking-tight text-ink-900 leading-[1.05]">
      {t('hero.title')}
    </h1>

    <p class="reveal mt-6 text-lg md:text-xl text-ink-500 leading-relaxed max-w-2xl mx-auto">
      {t('hero.subtitle')}
    </p>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#games" class="btn-primary">{t('hero.ctaPrimary')}</a>
      <a href="#contact" class="btn-ghost">{t('hero.ctaSecondary')}</a>
    </div>

    <p class="reveal mt-8 text-xs font-medium tracking-widest2 text-ink-400 uppercase">
      {t('hero.badge')}
    </p>
  </div>

  <!-- Visual abstracto: grid de cards con líneas doradas -->
  <div class="container-z mt-16 reveal">
    <div class="relative rounded-sm border border-ink-100 bg-ink-50/50 p-8 md:p-12 shadow-soft">
      <span class="hairline-gold absolute top-0 left-0"></span>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-ink-100">
        {['01','02','03','04'].map((n) => (
          <div class="bg-white p-6 md:p-8 aspect-[4/3] flex flex-col justify-between hover:border-gold-400 border border-transparent transition-colors">
            <span class="text-xs font-semibold text-gold-600 tracking-widest2">{n}</span>
            <div class="space-y-2">
              <div class="h-2 w-2/3 bg-ink-200 rounded-full"></div>
              <div class="h-2 w-1/2 bg-ink-100 rounded-full"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
