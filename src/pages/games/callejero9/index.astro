---
// Página Astro delgada que sirve el juego Callejero 9 desde /public/games/callejero9/
// El juego vive como HTML autocontenido en public/ para máxima portabilidad (fácil
// de embeber como iframe en operadores). Esta página solo expone la URL limpia.
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const htmlPath = resolve(process.cwd(), 'public/games/callejero9/index.html');
const html = readFileSync(htmlPath, 'utf-8');

// El HTML ya tiene su propia estructura completa (doctype, head, body).
// Lo servimos tal cual sin el layout de Astro.
const fullHtml = html;
---

<Fragment set:html={fullHtml} />
