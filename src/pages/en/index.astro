---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import GamePreview from '../../components/GamePreview.astro';
import Features from '../../components/Features.astro';
import Solutions from '../../components/Solutions.astro';
import Technology from '../../components/Technology.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';

const t = useTranslations('en');
---

<Layout title={t('meta.title')} description={t('meta.description')}>
  <Navbar />
  <main>
    <Hero />
    <TrustBar />
    <GamePreview />
    <Features />
    <Solutions />
    <Technology />
    <CTASection />
  </main>
  <Footer />
</Layout>
